# CONFIGURATION GENERALE
DEBUG=False
SECRET_KEY=votre-cle-secrete-ici
ALLOWED_HOSTS=bomoko.app,api.bomoko.app
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://bomoko.app,https://app.bomoko.app
CSRF_TRUSTED_ORIGINS=https://bomoko.app,https://app.bomoko.app
OTP_BYPASS_CODE=

# BASE DE DONNEES (PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/db

# IA
GEMINI_API_KEY=votre-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CELERY & REDIS
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# SMS / TRACKING SOS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_TRACKING_BASE_URL=https://api.bomoko.app
SOS_TRACKING_TOKEN_TTL_HOURS=72

# SECURITE SOS
SOS_MIN_CONTACTS_REQUIRED=3
SOS_AUDIO_ENCRYPTION_ENABLED=True
SOS_AUDIO_ENCRYPTION_KEY=
SOS_AUDIO_RETENTION_ENABLED=True
SOS_AUDIO_RETENTION_DAYS=90

# NOTIFICATIONS PUSH (Expo)
NOTIFICATIONS_ENABLE_PUSH=True
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# FORUM MODERATION
FORUM_BLOCKED_KEYWORDS=viol,rape,porn,pornographie,pedophile
FORUM_FLAGGED_KEYWORDS=harcelement,harcelement,chantage,sexe contre points,agression
